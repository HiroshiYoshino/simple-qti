<?xml version="1.0" encoding="UTF-8"?>
<qti-assessment-item
  xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.imsglobal.org/xsd/imsqtiasi_v3p0 https://purl.imsglobal.org/spec/qti/v3p0/schema/xsd/imsqti_asiv3p0_v1p0.xsd"
  identifier="diceNetAssemble01"
  title="サイコロの展開図判定"
  adaptive="false"
  time-dependent="false"
>
  <qti-response-declaration identifier="RESPONSE" cardinality="single" base-type="string">
    <qti-correct-response>
      <qti-value>B</qti-value>
    </qti-correct-response>
  </qti-response-declaration>

  <qti-outcome-declaration identifier="SCORE" cardinality="single" base-type="float">
    <qti-default-value>
      <qti-value>0</qti-value>
    </qti-default-value>
  </qti-outcome-declaration>

  <qti-item-body>
    <div>
      <h3>3つの展開図風の図から、実際にサイコロを組み立てられるものを1つ選んでください</h3>
      <p>選択後、展開図が立方体になるかどうかのアニメーションと説明が表示されます。</p>

      <qti-portable-custom-interaction
        response-identifier="RESPONSE"
        module="diceNetPci"
        custom-interaction-type-identifier="urn:example.jp:pci:dice-net:v1"
      >
        <qti-interaction-modules>
          <qti-interaction-module id="diceNetPci" primary-path="modules/dice_net_pci.js"/>
        </qti-interaction-modules>
        <qti-interaction-markup>
          <div class="dice-net-root"></div>
        </qti-interaction-markup>
      </qti-portable-custom-interaction>
    </div>
  </qti-item-body>

  <qti-response-processing template="https://www.imsglobal.org/question/qti_v3p0/rptemplates/match_correct"/>
</qti-assessment-item>
